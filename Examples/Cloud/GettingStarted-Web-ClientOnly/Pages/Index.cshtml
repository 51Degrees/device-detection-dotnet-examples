@page
@model FiftyOne.DeviceDetection.Examples.Cloud.GettingStartedWeb.ClientOnly.Pages.Model
@{
    ViewData["Title"] = "Client Only - Cloud Example";
    var resourceUrl = $"{Model.CloudEndPoint}/api/v4/{Model.ResourceKey}.js";
}

<div class="c-eg-page">
    <h2 class="c-eg-page__title">Client-side only example</h2>
    <p class="c-eg-page__lead">
        Detection runs entirely client-side. The 51Degrees JavaScript collects evidence in the browser
        and populates the results below once it completes, with no server-side rendering.
    </p>
    <div id="content"></div>
</div>

@* The cloud resource script raises the 'complete' event with the detection
    results. The shared examples.js helper subscribes to it and appends the
    results table into #content. *@
<script async src="@resourceUrl" type="text/javascript"></script>
<script src="~/js/examples.min.js"></script>
<script>
    window.onload = function () {
        fodExamples.bindDeviceCallback({ targetId: "content" });
    };
</script>
